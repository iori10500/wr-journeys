<!DOCTYPE html>
<html lang="<%= lang === 'en' ? 'en' : 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= lang === 'en' ? 'Brand House | WR Journeys' : '品牌矩阵 | WR Journeys' %></title>
  <meta name="description" content="<%= lang === 'en' ? 'WR Journeys — a slow-luxury brand house. Own brands Wildroad & Wanderway, curated partners Jianglu, Songtsam, Explora and more.' : 'WR Journeys 多品牌甄选之家。自营品牌野路逸行与万德，精选合作匠庐、松赞、Explora 等。' %>">
  <link rel="canonical" href="https://itinerary.wildroadgroup.com<%= lang === 'en' ? '/en' : '' %>/brands">
  <link rel="alternate" hreflang="zh-CN" href="https://itinerary.wildroadgroup.com/brands">
  <link rel="alternate" hreflang="en" href="https://itinerary.wildroadgroup.com/en/brands">
  <link rel="alternate" hreflang="x-default" href="https://itinerary.wildroadgroup.com/brands">
  <meta property="og:title" content="<%= lang === 'en' ? 'Brand House | WR Journeys' : '品牌矩阵 | WR Journeys' %>">
  <meta property="og:url" content="https://itinerary.wildroadgroup.com<%= lang === 'en' ? '/en' : '' %>/brands">
  <meta property="og:type" content="website">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
  <link rel="stylesheet" href="/fonts/fonts.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/main.css">
  <style>
    .brand-hero { background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 100%); padding: 60px 24px 48px; text-align: center; margin-bottom: 40px; }
    .brand-hero h1 { color: #fff; font-family: 'Playfair Display',serif; font-size: 36px; margin-bottom: 8px; }
    .brand-hero p { color: rgba(255,255,255,0.6); font-size: 14px; max-width: 620px; margin: 0 auto; }
    .brand-section { max-width: 1200px; margin: 0 auto 40px; padding: 0 24px; }
    .brand-section h2 { font-family: 'Playfair Display',serif; font-size: 22px; color: #2d2d44; margin: 32px 0 16px; border-left: 3px solid #c9a96a; padding-left: 12px; }
    .brand-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    .brand-card { background: #fff; border-radius: 14px; padding: 24px; box-shadow: 0 2px 16px rgba(0,0,0,0.06); text-decoration: none; color: inherit; transition: transform 0.2s; display: flex; flex-direction: column; min-height: 200px; }
    .brand-card:hover { transform: translateY(-4px); }
    .brand-name { font-family: 'Playfair Display',serif; font-size: 20px; color: #2d2d44; margin: 0 0 4px; }
    .brand-tagline { font-size: 13px; color: #c9a96a; margin: 0 0 12px; font-weight: 500; }
    .brand-summary { font-size: 14px; color: #555; line-height: 1.6; flex-grow: 1; margin: 0; }
    .brand-meta { font-size: 12px; color: #999; margin-top: 12px; }
    .brand-external { font-size: 11px; color: #c9a96a; }
  </style>
<%- include('partials/jsonld') %>
<%- include('partials/ga') %>
</head>
<body>
  <%- include("partials/header") %>
  <button id="langToggle" onclick="toggleLang()" class="lang-toggle"><%= lang === 'en' ? '中' : 'EN' %></button>

  <div class="brand-hero">
    <a href="<%= lang === 'en' ? '/en' : '' %>/" style="color:rgba(255,255,255,0.5);font-size:13px;text-decoration:none;display:block;margin-bottom:12px;"><%= lang === 'en' ? '← Home' : '← 返回首页' %></a>
    <h1><%= lang === 'en' ? 'A Slow-Luxury Brand House' : '多品牌甄选之家' %></h1>
    <p><%= lang === 'en' ? 'Own brands and hand-picked partners — every name curated for slow stays and quiet luxury.' : '自营品牌与精选合作伙伴 — 每一个品牌都符合慢奢生活与甄选品味。' %></p>
  </div>

  <% const groups = [
    { key: 'own', label_zh: '自营品牌', label_en: 'Own Brands' },
    { key: 'partner-curated', label_zh: '精选合作（站内）', label_en: 'Curated Partners' },
    { key: 'partner-external', label_zh: '精选合作（独立站）', label_en: 'Partner Brands · Linked Sites' }
  ]; %>

  <% groups.forEach(function(g) {
    const items = brands.filter(b => b.type === g.key);
    if (!items.length) return; %>
  <div class="brand-section">
    <h2><%= lang === 'en' ? g.label_en : g.label_zh %></h2>
    <div class="brand-grid">
      <% items.forEach(function(b) {
        const href = b.external ? b.external_url : (lang === 'en' ? '/en' : '') + '/brands/' + b.slug; %>
      <a class="brand-card" href="<%= href %>"<%= b.external ? ' target="_blank" rel="noopener"' : '' %>>
        <div class="brand-name"><%= lang === 'en' ? b.name_en : b.name_zh %></div>
        <div class="brand-tagline"><%= lang === 'en' ? b.tagline_en : b.tagline_zh %></div>
        <p class="brand-summary"><%= lang === 'en' ? b.summary_en : b.summary_zh %></p>
        <% if (b.external) { %>
        <div class="brand-meta"><span class="brand-external"><%= lang === 'en' ? '↗ Visit partner site' : '↗ 访问合作伙伴站点' %></span></div>
        <% } %>
      </a>
      <% }); %>
    </div>
  </div>
  <% }); %>

  <%- include("partials/footer") %>
  <script>function toggleLang(){const u=new URL(window.location);const p=u.pathname;const isEn=p==="/en"||p.startsWith("/en/");const np=isEn?(p==="/en"?"/":p.substring(3)):(p==="/"?"/en":"/en"+p);localStorage.setItem("wr_lang",isEn?"zh":"en");u.pathname=np;u.searchParams.delete("lang");window.location=u.toString()}</script>
</body>
</html>
