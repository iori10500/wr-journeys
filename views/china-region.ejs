<!DOCTYPE html>
<html lang="<%= lang === 'en' ? 'en' : 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= lang === 'en' ? region.headline_en : region.headline_zh %>">
  <link rel="canonical" href="https://itinerary.wildroadgroup.com<%= lang === 'en' ? '/en' : '' %>/destinations/china/<%= region.slug %>">
  <link rel="alternate" hreflang="zh-CN" href="https://itinerary.wildroadgroup.com/destinations/china/<%= region.slug %>">
  <link rel="alternate" hreflang="en" href="https://itinerary.wildroadgroup.com/en/destinations/china/<%= region.slug %>">
  <link rel="alternate" hreflang="x-default" href="https://itinerary.wildroadgroup.com/destinations/china/<%= region.slug %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:url" content="https://itinerary.wildroadgroup.com<%= lang === 'en' ? '/en' : '' %>/destinations/china/<%= region.slug %>">
  <meta property="og:type" content="website">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
  <link rel="stylesheet" href="/fonts/fonts.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/main.css">
  <style>
    .cr-hero { background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 100%); padding: 56px 24px 44px; text-align: center; }
    .cr-hero .breadcrumb { color: rgba(255,255,255,0.5); font-size: 12px; margin-bottom: 12px; }
    .cr-hero .breadcrumb a { color: #c8a96e; text-decoration: none; }
    .cr-hero h1 { color: #fff; font-family: 'Playfair Display', serif; font-size: 36px; margin: 0 0 10px; }
    .cr-hero .sub { color: rgba(255,255,255,0.7); font-size: 15px; max-width: 680px; margin: 0 auto; }
    .cr-body { max-width: 760px; margin: 0 auto; padding: 40px 24px 28px; font-size: 16px; line-height: 1.85; color: #333; }
    .cr-body p { margin: 0 0 18px; }
    .cr-routes { max-width: 1200px; margin: 0 auto; padding: 0 24px 80px; }
    .cr-section-title { font-family: 'Playfair Display', serif; font-size: 24px; color: #1a1a2e; margin: 24px 0 20px; border-bottom: 1px solid #e8e5dd; padding-bottom: 10px; }
    .cr-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; }
    .cr-card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 16px rgba(0,0,0,0.06); text-decoration: none; color: inherit; display: block; transition: transform 0.2s; }
    .cr-card:hover { transform: translateY(-3px); }
    .cr-card .img { position: relative; height: 180px; background: #1a1a2e; overflow: hidden; }
    .cr-card .img picture, .cr-card .img img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .cr-card .img .badge { position: absolute; top: 12px; left: 12px; background: rgba(0,0,0,0.55); color: #fff; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 20px; }
    .cr-card .body { padding: 14px 18px 18px; }
    .cr-card .title { font-size: 16px; font-weight: 500; color: #1a1a2e; margin: 0 0 6px; line-height: 1.4; }
    .cr-card .sub { font-size: 12px; color: #888; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .cr-empty { background: #f7f5f0; border-left: 3px solid #c8a96e; padding: 22px 26px; border-radius: 4px; }
    .cr-empty a { color: #c8a96e; text-decoration: none; font-weight: 500; }
    @media (max-width:640px) { .cr-hero h1 { font-size: 26px; } .cr-body { padding: 28px 20px 16px; } }
  </style>
<%- include('partials/jsonld') %>
<%- include('partials/ga') %>
</head>
<body>
  <%- include("partials/header") %>
  <button id="langToggle" onclick="toggleLang()" class="lang-toggle"><%= lang === 'en' ? '中' : 'EN' %></button>

  <section class="cr-hero">
    <div class="breadcrumb">
      <a href="<%= lang === 'en' ? '/en' : '' %>/"><%= lang === 'en' ? 'Home' : '首页' %></a>
      &nbsp;·&nbsp; <a href="<%= lang === 'en' ? '/en' : '' %>/destinations"><%= lang === 'en' ? 'Destinations' : '目的地' %></a>
      &nbsp;·&nbsp; <a href="<%= lang === 'en' ? '/en' : '' %>/destinations/china"><%= lang === 'en' ? 'China' : '中国' %></a>
    </div>
    <h1><%= lang === 'en' ? region.headline_en : region.headline_zh %></h1>
    <p class="sub"><%= lang === 'en' ? region.name_en : region.name_zh %></p>
  </section>

  <div class="cr-body">
    <% (lang === 'en' ? region.manifesto_en : region.manifesto_zh).split(/\n\n+/).forEach(function(para) { %>
    <p><%= para %></p>
    <% }); %>
  </div>

  <div class="cr-routes">
    <% if (routes && routes.length) { %>
    <h2 class="cr-section-title"><%= lang === 'en' ? 'Curated Routes (' + routes.length + ')' : '甄选线路（' + routes.length + ' 条）' %></h2>
    <div class="cr-grid">
      <% routes.forEach(function(r) { %>
      <a class="cr-card" href="<%= lang === 'en' ? '/en' : '' %>/routes/<%= r.slug %>">
        <div class="img">
          <picture>
            <source srcset="<%= r.hero_path.replace(/\.jpg$/, '.webp') %>" type="image/webp">
            <img src="<%= r.hero_path %>" alt="<%= lang === 'en' ? r.title_en : r.title_zh %>" loading="lazy">
          </picture>
          <div class="badge"><%= lang === 'en' ? r.duration_en : r.duration_zh %></div>
        </div>
        <div class="body">
          <div class="title"><%= lang === 'en' ? r.title_en : r.title_zh %></div>
          <div class="sub"><%= lang === 'en' ? r.subtitle_en : r.subtitle_zh %></div>
        </div>
      </a>
      <% }); %>
    </div>
    <% } else { %>
    <div class="cr-empty">
      <%= lang === 'en' ? 'No public routes yet for this region — we curate bespoke. ' : '本区域暂无公开线路，按一事一议设计。' %>
      <a href="https://wr-travel.com/contact" target="_blank" rel="noopener"><%= lang === 'en' ? 'Contact Advisor →' : '联系顾问 →' %></a>
    </div>
    <% } %>
  </div>

  <%- include("partials/footer") %>
  <script>function toggleLang(){const u=new URL(window.location);const p=u.pathname;const isEn=p==="/en"||p.startsWith("/en/");const np=isEn?(p==="/en"?"/":p.substring(3)):(p==="/"?"/en":"/en"+p);localStorage.setItem("wr_lang",isEn?"zh":"en");u.pathname=np;u.searchParams.delete("lang");window.location=u.toString()}</script>
</body>
</html>
