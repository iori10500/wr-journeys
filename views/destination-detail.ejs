<!DOCTYPE html>
<html lang="<%= lang === 'en' ? 'en' : 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= lang === 'en' ? destination.name_en : destination.name_zh %> · <%= lang === 'en' ? 'WR Travel' : '野路逸行' %></title>
  <meta name="description" content="<%= lang === 'en' ? destination.description_en : destination.description_zh %>">
  <meta property="og:title" content="<%= lang === 'en' ? destination.name_en : destination.name_zh %> · WR Travel">
  <meta property="og:description" content="<%= lang === 'en' ? destination.description_en : destination.description_zh %>">
  <meta property="og:url" content="https://itinerary.wildroadgroup.com/destinations/<%= destination.slug %>">
  <meta property="og:type" content="website">
  <link rel="canonical" href="https://itinerary.wildroadgroup.com/destinations/<%= destination.slug %>">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
  <link rel="stylesheet" href="/fonts/fonts.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/main.css">
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": lang === 'en' ? 'Itineraries' : '行程手册', "item": "https://itinerary.wildroadgroup.com/" },
      { "@type": "ListItem", "position": 2, "name": lang === 'en' ? 'Destinations' : '目的地', "item": "https://itinerary.wildroadgroup.com/destinations" },
      { "@type": "ListItem", "position": 3, "name": lang === 'en' ? destination.name_en : destination.name_zh, "item": "https://itinerary.wildroadgroup.com/destinations/" + destination.slug }
    ]
  }) %>
  </script>
  <style>
    .dest-detail-hero {
      position: relative;
      padding: 80px 24px 60px;
      text-align: center;
      overflow: hidden;
    }
    .dest-detail-hero .hero-bg {
      position: absolute; inset: 0;
      background-size: cover; background-position: center;
    }
    .dest-detail-hero .hero-bg::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(to bottom, rgba(26,26,46,0.6), rgba(26,26,46,0.85));
    }
    .dest-detail-hero .back-link { position:relative; z-index:1; color: rgba(255,255,255,0.5); font-size: 13px; text-decoration: none; display: block; margin-bottom: 16px; }
    .dest-detail-hero h1 { position:relative; z-index:1; color: #fff; font-family: 'Playfair Display',serif; font-size: 34px; margin: 0 0 8px; }
    .dest-detail-hero .desc { position:relative; z-index:1; color: rgba(255,255,255,0.75); font-size: 14px; max-width: 600px; margin: 0 auto; line-height: 1.8; }
    .gallery-section { max-width: 1200px; margin: 0 auto; padding: 40px 24px 0; }
    .gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
    .gallery-grid img { width: 100%; height: 160px; object-fit: cover; border-radius: 10px; transition: transform 0.3s; cursor: pointer; }
    .gallery-grid img:hover { transform: scale(1.03); }
    .trips-section { max-width: 1200px; margin: 40px auto; padding: 0 24px 80px; }
    .trips-section h2 { font-size: 22px; margin-bottom: 20px; color: #333; }
  </style>
<%- include('partials/ga') %>
</head>
<body>
  <button id="langToggle" onclick="toggleLang()" class="lang-toggle"><%= lang === 'en' ? '中' : 'EN' %></button>

  <div class="dest-detail-hero">
    <% if (destination.coverImage) { %>
    <div class="hero-bg" style="background-image:url('/<%= destination.coverImage %>');"></div>
    <% } else { %>
    <div class="hero-bg" style="background:linear-gradient(135deg,#1a1a2e 0%,#2d2d44 100%);"></div>
    <% } %>
    <a href="/destinations<%= lang === 'en' ? '?lang=en' : '' %>" class="back-link"><%= lang === 'en' ? '← All destinations' : '← 全部目的地' %></a>
    <h1><%= lang === 'en' ? destination.name_en : destination.name_zh %></h1>
    <p class="desc"><%= lang === 'en' ? destination.description_en : destination.description_zh %></p>
  </div>

  <% if (destination.gallery && destination.gallery.length > 0) { %>
  <div class="gallery-section">
    <div class="gallery-grid">
      <% destination.gallery.forEach(function(img) { %>
        <picture>
          <source srcset="/<%= img.replace(/\.(jpg|jpeg|png)$/i, '.webp') %>" type="image/webp">
          <img src="/<%= img %>" alt="<%= lang === 'en' ? destination.name_en : destination.name_zh %>" loading="lazy" decoding="async">
        </picture>
      <% }); %>
    </div>
  </div>
  <% } %>

  <div class="trips-section">
    <h2><%= lang === 'en' ? 'Itineraries in ' + destination.name_en : destination.name_zh + ' 的行程' %></h2>
    <% if (trips.length > 0) { %>
    <div class="grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:28px;">
      <% trips.forEach(function(item) {
        var isEn = lang === 'en';
        var cardTitle = isEn ? (item.title_en || item.title) : item.title;
        var cardDesc = isEn ? (item.description_en || item.description) : item.description;
      %>
        <a class="card" href="/<%= item.id %><%= isEn ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.06);transition:transform 0.3s;">
          <div style="position:relative;height:200px;overflow:hidden;">
            <picture>
              <source srcset="/<%= item.coverImage.replace(/\.(jpg|jpeg|png)$/i, '.webp') %>" type="image/webp">
              <img src="/<%= item.coverImage %>" alt="<%= cardTitle %>" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;">
            </picture>
            <div style="position:absolute;top:16px;left:16px;background:rgba(0,0,0,0.55);color:#fff;font-size:12px;font-weight:600;padding:6px 14px;border-radius:20px;"><%= isEn ? item.days + 'D ' + (item.days - 1) + 'N' : item.days + '天' + (item.days - 1) + '晚' %></div>
          </div>
          <div style="padding:16px;">
            <h3 style="font-size:16px;margin:0 0 4px;"><%= cardTitle %></h3>
            <p style="font-size:13px;color:#888;margin:0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= cardDesc %></p>
          </div>
        </a>
      <% }); %>
    </div>
    <% } else { %>
    <div style="text-align:center;padding:60px 24px;">
      <p style="font-size:18px;color:#888;margin-bottom:24px;"><%= lang === 'en' ? 'Coming Soon — Custom itineraries for ' + destination.name_en : destination.name_zh + ' 定制行程即将推出' %></p>
      <a href="https://wr-travel.com/contact" target="_blank" rel="noopener" style="display:inline-block;background:linear-gradient(135deg,#c8a96e,#b08d4a);color:#fff;font-size:16px;font-weight:600;padding:14px 32px;border-radius:8px;text-decoration:none;"><%= lang === 'en' ? 'Consult a Travel Advisor' : '咨询旅行顾问' %></a>
    </div>
    <% } %>
  </div>

  <script>
    function toggleLang() {
      const url = new URL(window.location); const next = url.searchParams.get('lang') === 'en' ? 'zh' : 'en';
      localStorage.setItem('wr_lang', next); url.searchParams.set('lang', next); window.location = url.toString();
    }
  </script>
</body>
</html>
