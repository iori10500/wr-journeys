<!DOCTYPE html>
<html lang="<%= lang === 'en' ? 'en' : 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= lang === 'en' ? 'Curated global luxury custom itineraries. Direct hotel contracts, private journeys, 24/7 concierge.' : '精選全球奢華定制行程，奢華酒店直簽，私人定制，24小時旅行管家服務。' %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= lang === 'en' ? 'Curated global luxury custom itineraries.' : '精選全球奢華定制行程，奢華酒店直簽，私人定制。' %>">
  <meta property="og:image" content="https://itinerary.wildroadgroup.com/<%= itineraries[0] ? itineraries[0].coverImage : '' %>">
  <meta property="og:url" content="https://itinerary.wildroadgroup.com/<%= lang === 'en' ? '?lang=en' : '' %>">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="WR Travel">
  <meta property="og:locale" content="<%= lang === 'en' ? 'en_US' : 'zh_CN' %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= lang === 'en' ? 'Curated global luxury custom itineraries.' : '精選全球奢華定制行程。' %>">
  <meta name="twitter:image" content="https://itinerary.wildroadgroup.com/<%= itineraries[0] ? itineraries[0].coverImage : '' %>">
  <link rel="canonical" href="https://itinerary.wildroadgroup.com/">
  <link rel="alternate" hreflang="zh" href="https://itinerary.wildroadgroup.com/">
  <link rel="alternate" hreflang="en" href="https://itinerary.wildroadgroup.com/?lang=en">
  <link rel="alternate" hreflang="x-default" href="https://itinerary.wildroadgroup.com/">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": lang === 'en' ? 'WR Travel Itineraries' : '野路逸行行程手册',
    "url": "https://itinerary.wildroadgroup.com",
    "description": lang === 'en' ? 'Curated luxury travel itineraries — Switzerland, Tanzania, Thailand and more' : '野路逸行（WR Travel）精选行程手册 — 瑞士、坦桑尼亚、泰国等目的地高端定制旅行',
    "inLanguage": ["zh-CN", "en"],
    "publisher": { "@type": "Organization", "name": "野路逸行 WR Travel", "url": "https://wr-travel.com" }
  }) %>
  </script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": lang === 'en' ? 'Featured Itineraries' : '精选行程',
    "numberOfItems": itineraries.length,
    "itemListElement": itineraries.map(function(item, i) { return {
      "@type": "ListItem",
      "position": i + 1,
      "url": "https://itinerary.wildroadgroup.com/" + item.id,
      "name": lang === 'en' ? (item.title_en || item.title) : item.title
    }})
  }) %>
  </script>
  <link rel="stylesheet" href="/fonts/fonts.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/main.css">
<%- include('partials/ga') %>
</head>
<body>
  <%- include("partials/header") %>

  <!-- Language Toggle -->
  <button id="langToggle" onclick="toggleLang()" class="lang-toggle"><%= lang === 'en' ? '中' : 'EN' %></button>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-brand">WR Journeys</div>
      <h1 class="hero-title"><%= lang === 'en' ? 'A Slow-Luxury Brand House' : '慢奢策展之家' %></h1>
      <p class="hero-sub"><%= lang === 'en' ? 'Slow stays, deep stories, hand-picked brands — curated by Wildroad &amp; Wanderway.' : '慢栖、深度叙事、精选品牌 — 由野路逸行与万德策展。' %></p>
    </div>
  </section>

  <!-- BRAND HOUSE (Featured Brands strip) -->
  <section class="brand-house">
    <div class="bh-inner">
      <div class="bh-head">
        <div class="bh-kicker"><%= lang === 'en' ? 'BRAND HOUSE' : '品牌矩阵' %></div>
        <h2 class="bh-title"><%= lang === 'en' ? 'Hand-picked names, one curatorial standard.' : '精挑细选，统一的策展标准。' %></h2>
        <a class="bh-more" href="/brands<%= lang === 'en' ? '?lang=en' : '' %>"><%= lang === 'en' ? 'See all brands →' : '查看全部品牌 →' %></a>
      </div>
      <div class="bh-grid">
        <% [
          { slug:'wildroad',  name_zh:'野路逸行', name_en:'Wildroad',  tag_zh:'中国入境定制旗舰',  tag_en:'Inbound China bespoke',     type_zh:'自营', type_en:'Own' },
          { slug:'wanderway', name_zh:'万德',     name_en:'Wanderway', tag_zh:'全球出境定制',       tag_en:'Outbound bespoke worldwide', type_zh:'自营', type_en:'Own' },
          { slug:'jianglu',   name_zh:'匠庐',     name_en:'Jianglu',   tag_zh:'中国精品酒店 · 9 条线路', tag_en:'CN boutique · 9 routes',  type_zh:'精选合作', type_en:'Curated' },
          { slug:'songtsam',  name_zh:'松赞',     name_en:'Songtsam',  tag_zh:'川滇藏精品酒店',     tag_en:'Tibetan plateau hotels',     type_zh:'精选合作', type_en:'Curated' }
        ].forEach(function(b) { %>
        <a class="bh-card" href="/brands/<%= b.slug %><%= lang === 'en' ? '?lang=en' : '' %>">
          <div class="bh-card-type"><%= lang === 'en' ? b.type_en : b.type_zh %></div>
          <div class="bh-card-name"><%= lang === 'en' ? b.name_en : b.name_zh %></div>
          <div class="bh-card-tag"><%= lang === 'en' ? b.tag_en : b.tag_zh %></div>
        </a>
        <% }); %>
      </div>
      <div class="bh-cta">
        <span class="bh-cta-text"><%= lang === 'en' ? 'Planning a journey? Talk to a real advisor.' : '想策划一段旅程？联系真人顾问。' %></span>
        <a class="bh-cta-btn" href="https://wr-travel.com/contact" target="_blank" rel="noopener"><%= lang === 'en' ? 'Contact Advisor →' : '联系顾问 →' %></a>
      </div>
    </div>
  </section>
  <style>
    .brand-house { background:#0e0e1a; padding:48px 24px 56px; border-top:1px solid rgba(200,169,110,0.15); border-bottom:1px solid rgba(200,169,110,0.15); }
    .bh-inner { max-width:1200px; margin:0 auto; }
    .bh-head { display:flex; align-items:baseline; gap:20px; flex-wrap:wrap; margin-bottom:24px; }
    .bh-kicker { color:#c8a96e; font-size:11px; letter-spacing:0.2em; font-weight:600; }
    .bh-title { color:#fff; font-family:'Playfair Display',serif; font-size:24px; font-weight:400; margin:0; flex:1; min-width:220px; }
    .bh-more { color:#c8a96e; font-size:13px; text-decoration:none; white-space:nowrap; }
    .bh-more:hover { color:#e0c290; }
    .bh-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:14px; }
    .bh-card { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:20px; text-decoration:none; color:inherit; transition:transform 0.2s, border-color 0.2s; display:flex; flex-direction:column; gap:6px; }
    .bh-card:hover { transform:translateY(-3px); border-color:rgba(200,169,110,0.5); }
    .bh-card-type { color:#c8a96e; font-size:10px; letter-spacing:0.15em; font-weight:600; text-transform:uppercase; }
    .bh-card-name { color:#fff; font-family:'Playfair Display',serif; font-size:20px; font-weight:500; }
    .bh-card-tag { color:rgba(255,255,255,0.6); font-size:13px; line-height:1.5; }
    .bh-cta { margin-top:28px; display:flex; align-items:center; justify-content:center; gap:18px; flex-wrap:wrap; padding:18px 24px; background:rgba(200,169,110,0.06); border-radius:10px; }
    .bh-cta-text { color:rgba(255,255,255,0.75); font-size:14px; }
    .bh-cta-btn { background:linear-gradient(135deg,#c8a96e 0%,#b08d4a 100%); color:#fff; text-decoration:none; padding:10px 20px; border-radius:50px; font-size:14px; font-weight:600; transition:transform 0.2s; }
    .bh-cta-btn:hover { transform:scale(1.04); }
    @media (max-width:640px) { .bh-title { font-size:20px; } .bh-card-name { font-size:18px; } }
  </style>

  <!-- SEARCH -->
  <div class="search-section">
    <div class="search-wrapper">
      <span class="icon">🔍</span>
      <input type="text" id="searchInput" placeholder="<%= lang === 'en' ? 'Search itineraries (title, tags, destinations)' : '搜索行程（标题、标签、目的地）' %>" autocomplete="off">
      <button class="clear-btn" id="clearBtn">✕</button>
    </div>
    <div class="search-count" id="searchCount"><%= lang === 'en' ? itineraries.length + ' itineraries' : '共 ' + itineraries.length + ' 个行程' %></div>
  </div>

  <!-- GRID -->
  <div class="container">
    <div class="grid" id="itineraryGrid">
      <% itineraries.forEach(function(item) {
        var isEn = lang === 'en';
        var cardTitle = isEn ? (item.title_en || item.title) : item.title;
        var cardSubtitle = isEn ? (item.subtitle_en || item.subtitle) : item.subtitle;
        var cardDesc = isEn ? (item.description_en || item.description) : item.description;
        var cardTags = isEn ? (item.tags_en || item.tags) : item.tags;
      %>
        <a class="card" href="/<%= item.id %><%= isEn ? '?lang=en' : '' %>"
           data-title="<%= item.title %> <%= item.title_en || '' %>"
           data-tags="<%= (item.tags || []).join(',') %>,<%= (item.tags_en || []).join(',') %>"
           data-regions="<%= (item.regions || []).join(',') %>,<%= (item.regions_en || []).join(',') %>">
          <div class="card-image">
            <picture>
              <source srcset="/<%= item.coverImage.replace(/\.(jpg|jpeg|png)$/i, '.webp') %>" type="image/webp">
              <img src="/<%= item.coverImage %>" alt="<%= cardTitle %>" loading="lazy" decoding="async"
                   onerror="this.style.display='none'">
            </picture>
            <div class="gradient"></div>
            <div class="badge-days"><%= isEn ? item.days + 'D ' + (item.days - 1) + 'N' : item.days + '天' + (item.days - 1) + '晚' %></div>
            <div class="brand-tag"><%= item.brand %></div>
            <%
            var price = formatPrice(item, lang);
            if (price.text) { 
              var priceClass = item.priceType === 'custom' ? 'font-size:14px;font-weight:500;' : '';
            %>
              <div class="price-tag" style="<%= priceClass %>"><%= price.text %><small> <%= price.sub %></small></div>
              <% if (price.discount) { %>
                <div class="price-tag" style="top:auto;bottom:48px;font-size:11px;background:rgba(200,169,110,0.85);padding:3px 10px;border-radius:20px;right:16px;color:#fff;text-shadow:none;font-weight:600;"><%= price.discount %></div>
              <% } %>
            <% } %>
          </div>
          <div class="card-body">
            <div class="card-title"><%= cardTitle %></div>
            <div class="card-subtitle"><%= cardSubtitle %></div>
            <div class="card-desc"><%= cardDesc %></div>
            <div class="card-tags">
              <% (cardTags || []).slice(0, 4).forEach(function(tag) { %>
                <span class="card-tag"><%= tag %></span>
              <% }); %>
            </div>
            <div class="card-cta"><%= lang === 'en' ? 'View Details' : '查看详情' %></div>
          </div>
        </a>
      <% }); %>
    </div>
  </div>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <h2><%= lang === 'en' ? 'KOL Testimonials' : 'KOL 合作评价' %></h2>
    <div class="testimonial-grid">
      <div class="testimonial-card">
        <p class="quote"><%= lang === 'en' ? '"Received a 3-night Peninsula Bangkok experience through WR Travel. Clear process, exceeded expectations."' : '"通过 WR Travel 获得了曼谷半岛酒店 3 晚体验。合作流程清晰，入住体验超出预期。"' %></p>
        <p class="author">@TravelWithMing · <%= lang === 'en' ? 'Lifestyle Blogger' : '生活方式博主' %> · 120K</p>
      </div>
      <div class="testimonial-card">
        <p class="quote"><%= lang === 'en' ? '"First hotel collaboration, and the WR team guided me throughout. From submission to confirmation in just 3 days — professional and efficient."' : '"第一次做酒店合作，WR 团队全程协助。从提交到确认只用了 3 天，专业高效。"' %></p>
        <p class="author">@LuxeExplorer · <%= lang === 'en' ? 'Luxury Travel KOL' : '奢华旅行 KOL' %> · 85K</p>
      </div>
    </div>
  </section>
  <style>
    .testimonials { max-width:1200px; margin:0 auto; padding:60px 24px; }
    .testimonials h2 { text-align:center; font-size:24px; font-weight:300; letter-spacing:4px; margin-bottom:36px; color:#fff; }
    .testimonial-grid { display:grid; grid-template-columns:1fr 1fr; gap:24px; }
    .testimonial-card { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:16px; padding:32px; }
    .testimonial-card .quote { color:rgba(255,255,255,0.85); font-size:15px; font-style:italic; line-height:1.8; margin:0 0 16px; position:relative; padding-left:24px; }
    .testimonial-card .quote::before { content:'"'; position:absolute; left:0; top:-4px; font-size:32px; color:#c8a96e; font-family:Georgia,serif; }
    .testimonial-card .author { color:#c8a96e; font-size:13px; letter-spacing:0.5px; }
    @media (max-width:768px) { .testimonial-grid { grid-template-columns:1fr; } }
  </style>

  <!-- FOOTER -->
  <%- include("partials/footer") %>
  <div class="footer" style="display:none;">
    <strong>WanderWay Travel</strong> &middot; <%= lang === 'en' ? 'Direct Luxury Hotel Contracts · Custom Itineraries · 24/7 Travel Concierge' : '全球奢华酒店直签 · 私人定制行程 · 24小时旅行管家服务' %>
  </div>

  <script>
    // Lightweight i18n for dynamic content (search filtering)
    const LANG = '<%= lang %>';
    const I18N = {
      zh: {
        itinerary_count: '共 ${count} 个行程',
        no_results_title: '未找到相关行程',
        no_results_desc: '请尝试其他搜索词，如"米兰"、"瑞士"、"奢华"等',
      },
      en: {
        itinerary_count: '${count} itineraries',
        no_results_title: 'No Results Found',
        no_results_desc: 'Try other keywords like "Milan", "Switzerland", "Luxury"',
      }
    };
    function t(key) { return I18N[LANG][key] || key; }
    function tpl(key, vars) {
      let s = t(key);
      if (vars) for (const [k, v] of Object.entries(vars)) s = s.replace('${' + k + '}', v);
      return s;
    }

    function toggleLang() {
      const next = LANG === 'zh' ? 'en' : 'zh';
      localStorage.setItem('wr_lang', next);
      const url = new URL(window.location);
      url.searchParams.set('lang', next);
      window.location = url.toString();
    }

    function updateSearchCount() {
      const visible = cards.filter(c => c.style.display !== 'none').length;
      searchCount.textContent = tpl('itinerary_count', { count: visible });
    }

    const searchInput = document.getElementById('searchInput');
    const clearBtn = document.getElementById('clearBtn');
    const searchCount = document.getElementById('searchCount');
    const grid = document.getElementById('itineraryGrid');
    const cards = Array.from(grid.querySelectorAll('.card'));
    let emptyState = null;

    function filterCards(query) {
      const q = query.toLowerCase().trim();
      let count = 0;

      cards.forEach(card => {
        const title = card.dataset.title || '';
        const tags = card.dataset.tags || '';
        const regions = card.dataset.regions || '';

        const match = !q ||
          title.toLowerCase().includes(q) ||
          tags.toLowerCase().includes(q) ||
          regions.toLowerCase().includes(q);

        card.style.display = match ? '' : 'none';
        if (match) count++;
      });

      if (emptyState) { emptyState.remove(); emptyState = null; }

      if (count === 0) {
        emptyState = document.createElement('div');
        emptyState.className = 'empty-state';
        emptyState.innerHTML = '<span class="emoji">🔎</span><h3>' + t('no_results_title') + '</h3><p>' + t('no_results_desc') + '</p>';
        grid.appendChild(emptyState);
      }

      updateSearchCount();
      clearBtn.classList.toggle('visible', q.length > 0);
    }

    searchInput.addEventListener('input', (e) => { filterCards(e.target.value); });

    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      filterCards('');
      searchInput.focus();
    });
  </script>

  <!-- Floating Consult Button -->
  <a href="https://wr-travel.com/contact" target="_blank" rel="noopener" class="float-consult" aria-label="<%= lang === 'en' ? 'Consult' : '咨询' %>">💬 <%= lang === 'en' ? 'Consult' : '咨询' %></a>
  <style>
    .float-consult {
      position: fixed; bottom: 28px; right: 28px; z-index: 9999;
      display: flex; align-items: center; gap: 6px;
      background: linear-gradient(135deg, #c8a96e 0%, #b08d4a 100%);
      color: #fff; font-size: 15px; font-weight: 600;
      padding: 12px 22px; border-radius: 50px;
      text-decoration: none; box-shadow: 0 4px 20px rgba(200,169,110,0.4);
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .float-consult:hover {
      transform: scale(1.08);
      box-shadow: 0 6px 28px rgba(200,169,110,0.55);
    }
    @media (max-width: 640px) {
      .float-consult { bottom: 18px; right: 18px; font-size: 14px; padding: 10px 18px; }
    }
  </style>

</body>
</html>
