<!DOCTYPE html>
<html lang="<%= lang === 'en' ? 'en' : 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= itinerary ? (lang === 'en' ? (itinerary.description_en || '') : itinerary.description) : '' %>">
  <% if (itinerary) { %>
  <meta property="og:title" content="<%= lang === 'en' ? (itinerary.title_en || itinerary.title) : itinerary.title %> - WR Travel">
  <meta property="og:description" content="<%= lang === 'en' ? (itinerary.description_en || '') : itinerary.description %>">
  <meta property="og:image" content="https://itinerary.wildroadgroup.com/<%= itinerary.coverImage %>">
  <meta property="og:url" content="https://itinerary.wildroadgroup.com/<%= itinerary.id %><%= lang === 'en' ? '?lang=en' : '' %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= lang === 'en' ? (itinerary.title_en || itinerary.title) : itinerary.title %> - WR Travel">
  <meta name="twitter:description" content="<%= lang === 'en' ? (itinerary.description_en || '') : itinerary.description %>">
  <meta name="twitter:image" content="https://itinerary.wildroadgroup.com/<%= itinerary.coverImage %>">
  <link rel="canonical" href="https://itinerary.wildroadgroup.com/<%= itinerary.id %>">
  <link rel="alternate" hreflang="zh" href="https://itinerary.wildroadgroup.com/<%= itinerary.id %>">
  <link rel="alternate" hreflang="en" href="https://itinerary.wildroadgroup.com/<%= itinerary.id %>?lang=en">
  <link rel="alternate" hreflang="x-default" href="https://itinerary.wildroadgroup.com/<%= itinerary.id %>">
  <% } %>
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="WR Travel">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <% if (itinerary) { %>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "TouristTrip",
    "name": lang === 'en' ? (itinerary.title_en || itinerary.title) : itinerary.title,
    "description": lang === 'en' ? (itinerary.description_en || itinerary.description) : itinerary.description,
    "touristType": "Luxury",
    "duration": itinerary.days + "D" + (itinerary.days - 1) + "N",
    "image": "https://itinerary.wildroadgroup.com/" + itinerary.coverImage,
    "url": "https://itinerary.wildroadgroup.com/" + itinerary.id,
    "provider": {
      "@type": "TravelAgency",
      "name": itinerary.brand,
      "url": "https://wr-travel.com"
    },
    "areaServed": (lang === 'en' ? (itinerary.regions_en || itinerary.regions) : itinerary.regions).map(function(r) { return { "@type": "City", "name": r } }),
    "includes": (lang === 'en' ? (itinerary.tags_en || itinerary.tags) : itinerary.tags).map(function(t) { return { "@type": "TouristAttraction", "name": t } })
  }) %>
  </script>
  <% } %>
  
  
  <link rel="stylesheet" href="/fonts/fonts.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    
    :root {
      --gold: #c8a96e;
      --gold-light: #e8d5b0;
      --dark: #1a1a2e;
      --text: #3d3d5c;
      --text-light: #8888aa;
      --bg: #f7f5f2;
    }
    
    body {
      font-family: 'Inter', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }
    
    /* ===== TOP BAR ===== */
    .top-bar {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(26,26,46,0.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 12px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }
    .top-bar a {
      color: rgba(255,255,255,0.7);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      display: flex;
      align-items: center;
      gap: 6px;
      transition: color 0.2s;
    }
    .top-bar .download-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      color: var(--gold);
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      padding: 6px 14px;
      border: 1px solid var(--gold);
      border-radius: 6px;
      transition: all 0.2s;
    }
    .top-bar .download-btn:hover {
      background: var(--gold);
      color: #fff;
    }
    .top-bar .title {
      color: #fff;
      font-size: 14px;
      font-weight: 600;
      max-width: 50%;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    
    /* ===== METADATA BAR ===== */
    <% if (itinerary) { %>
    .meta-bar {
      background: #fff;
      border-bottom: 1px solid rgba(0,0,0,0.06);
      padding: 16px 24px;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 12px 20px;
    }
    .meta-bar .meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      color: var(--text-light);
    }
    .meta-bar .meta-item strong {
      color: var(--text);
      font-weight: 600;
    }
    .meta-bar .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
    }
    .meta-bar .tag {
      font-size: 11px;
      padding: 3px 10px;
      border-radius: 12px;
      background: rgba(200,169,110,0.10);
      color: var(--gold);
      border: 1px solid rgba(200,169,110,0.20);
    }
    <% } %>
    
    /* ===== BROCHURE FRAME ===== */
    .brochure-wrapper {
      max-width: 820px;
      margin: 0 auto;
      padding: 24px 16px 60px;
    }
    
    <% if (brochureContent) { %>
    .brochure-frame {
      width: 100%;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.06);
      overflow: hidden;
    }
    .brochure-content .cover,
    .brochure-content .page {
      width: 100% !important;
      max-width: 820px;
      margin: 0 auto;
    }
    .brochure-content .cover {
      height: auto;
      min-height: 400px;
    }
    <% } else { %>
    .not-found {
      text-align: center;
      padding: 80px 20px;
    }
    .not-found h2 {
      font-size: 24px;
      color: var(--dark);
      margin-bottom: 8px;
    }
    .not-found p {
      color: var(--text-light);
      font-size: 14px;
    }
    .not-found a {
      display: inline-block;
      margin-top: 20px;
      color: var(--gold);
      text-decoration: none;
      font-weight: 600;
    }
    <% } %>
    
    /* ===== LANG TOGGLE ===== */
    .lang-toggle {
      position: fixed;
      top: 16px;
      right: 16px;
      z-index: 1000;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(0,0,0,0.08);
      color: #333;
      font-size: 11px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      font-family: 'Inter', system-ui, sans-serif;
    }
    .lang-toggle:hover {
      background: #c8a96e;
      color: #fff;
      border-color: #c8a96e;
    }

    /* ===== FOOTER ===== */
    .footer {
      text-align: center;
      padding: 32px 24px;
      color: var(--text-light);
      font-size: 12px;
      border-top: 1px solid rgba(0,0,0,0.04);
    }
    
    /* ===== RELATED TRIPS ===== */
    .related-trips {
      max-width: 860px;
      margin: 48px auto 0;
      padding: 0 16px;
    }
    .related-heading {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 20px;
      font-weight: 500;
      color: #333;
      margin-bottom: 20px;
    }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }
    .related-card {
      text-decoration: none;
      color: inherit;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 16px rgba(0,0,0,0.06);
      transition: transform 0.2s, box-shadow 0.2s;
      background: #fff;
    }
    .related-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    }
    .related-card img {
      width: 100%;
      height: 140px;
      object-fit: cover;
    }
    .related-body {
      padding: 12px 14px;
    }
    .related-title {
      font-size: 14px;
      font-weight: 600;
      margin: 0;
      color: #333;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .related-days {
      font-size: 12px;
      color: #888;
      margin: 4px 0 0;
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 640px) {
      .top-bar { padding: 10px 16px; }
      .top-bar .title { font-size: 12px; max-width: 40%; }
      .meta-bar { padding: 12px 16px; flex-direction: column; align-items: flex-start; gap: 6px; }
      .brochure-wrapper { padding: 0 0 40px; max-width: 100%; }
      .brochure-frame { border-radius: 0; }
      .brochure-content .cover { min-height: 300px; }
    }
  </style>
</head>
<body>

  <!-- Language Toggle -->
  <button id="langToggle" onclick="toggleLang()" class="lang-toggle"><%= lang === 'en' ? '中' : 'EN' %></button>

  <!-- TOP BAR -->
  <div class="top-bar">
    <a href="/<%= lang === 'en' ? '?lang=en' : '' %>"><%= lang === 'en' ? '← Back to list' : '← 返回列表' %></a>
    <span class="title"><%= itinerary ? (lang === 'en' ? (itinerary.title_en || itinerary.title) : itinerary.title) : (lang === 'en' ? 'Not Found' : '未找到行程') %></span>
    <% if (itinerary) { %>
    <a href="/pdfs/<%= itinerary.id %>.pdf" class="download-btn" download><%= lang === 'en' ? '📥 Download PDF' : '📥 下载PDF' %></a>
    <% } else { %>
    <span></span>
    <% } %>
  </div>

  <% if (itinerary) { %>
  <!-- METADATA BAR -->
  <div class="meta-bar">
    <div class="meta-item">
      📅 <strong><%= lang === 'en' ? itinerary.days + 'D ' + (itinerary.days - 1) + 'N' : itinerary.days + '天' + (itinerary.days - 1) + '晚' %></strong>
    </div>
    <%
    var price = formatPrice(itinerary, lang);
    if (price.text) { %>
    <div class="meta-item">
      💰 <strong><%= price.text %></strong> <span style="font-size:12px;color:var(--text-light);"><%= price.sub %></span>
    </div>
    <% if (price.discount) { %>
    <div class="meta-item">
      🏷️ <span class="tag" style="background:rgba(200,169,110,0.15);"><%= price.discount %></span>
    </div>
    <% } %>
    <% } %>
    <div class="meta-item">
      🏷️ 
      <div class="tags">
        <% var detailTags = lang === 'en' ? (itinerary.tags_en || itinerary.tags) : itinerary.tags;
        (detailTags || []).forEach(function(tag) { %>
          <span class="tag"><%= tag %></span>
        <% }); %>
      </div>
    </div>
  </div>
  <% } %>

  <!-- BROCHURE CONTENT -->
  <div class="brochure-wrapper">
    <% if (brochureContent) { %>
      <div class="brochure-frame">
        <div class="brochure-content">
          <%- brochureContent.styles %>
          <%- brochureContent.bodyContent %>
        </div>
      </div>
    <% } else { %>
      <div class="not-found">
        <h2><%= lang === 'en' ? 'Itinerary Not Found' : '行程未找到' %></h2>
        <p><%= lang === 'en' ? 'This itinerary does not exist or has been removed' : '该行程手册不存在或已被移除' %></p>
        <a href="/<%= lang === 'en' ? '?lang=en' : '' %>"><%= lang === 'en' ? '← Back to home' : '← 返回首页浏览其他行程' %></a>
      </div>
    <% } %>
  </div>

  <% if (itinerary && itineraries) { %>
  <div class="related-trips">
    <h3 class="related-heading"><%= lang === 'en' ? 'Related Itineraries' : '相关行程' %></h3>
    <div class="related-grid">
      <% itineraries.filter(function(r) { return r.id !== itinerary.id; }).slice(0, 3).forEach(function(rel) { %>
        <a href="/<%= rel.id %><%= lang === 'en' ? '?lang=en' : '' %>" class="related-card">
          <picture>
            <source srcset="/<%= rel.coverImage.replace(/\.(jpg|jpeg|png)$/i, '.webp') %>" type="image/webp">
            <img src="/<%= rel.coverImage %>" alt="<%= lang === 'en' ? (rel.title_en || rel.title) : rel.title %>" loading="lazy" decoding="async">
          </picture>
          <div class="related-body">
            <p class="related-title"><%= lang === 'en' ? (rel.title_en || rel.title) : rel.title %></p>
            <p class="related-days"><%= rel.days %><%= lang === 'en' ? ' Days' : '天' %></p>
          </div>
        </a>
      <% }); %>
    </div>
  </div>
  <% } %>

  <div class="footer">
    <strong>WanderWay Travel</strong> · <%= lang === 'en' ? 'Global Luxury Custom Travel' : '全球奢华定制旅行' %>
  </div>

<script>
  function toggleLang() {
    const url = new URL(window.location);
    const next = url.searchParams.get('lang') === 'en' ? 'zh' : 'en';
    localStorage.setItem('wr_lang', next);
    url.searchParams.set('lang', next);
    window.location = url.toString();
  }
</script>

</body>
</html>
