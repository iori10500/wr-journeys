<!DOCTYPE html>
<html lang="<%= lang === 'en' ? 'en' : 'zh-CN' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= lang === 'en' ? guide.title_en : guide.title_zh %> | WR Travel</title>
  <meta name="description" content="<%= lang === 'en' ? guide.title_en + ' — expert travel guide by WR Travel' : guide.title_zh + ' — 野路逸行专业旅行指南' %>">
  <link rel="canonical" href="https://itinerary.wildroadgroup.com/journal/<%= guide.slug %>">
  <link rel="alternate" hreflang="zh" href="https://itinerary.wildroadgroup.com/journal/<%= guide.slug %>">
  <link rel="alternate" hreflang="en" href="https://itinerary.wildroadgroup.com/journal/<%= guide.slug %>?lang=en">
  <link rel="alternate" hreflang="x-default" href="https://itinerary.wildroadgroup.com/journal/<%= guide.slug %>">
  <meta property="og:title" content="<%= lang === 'en' ? guide.title_en : guide.title_zh %> | WR Travel">
  <meta property="og:description" content="<%= lang === 'en' ? guide.title_en + ' — expert travel guide by WR Travel' : guide.title_zh + ' — 野路逸行专业旅行指南' %>">
  <meta property="og:url" content="https://itinerary.wildroadgroup.com/journal/<%= guide.slug %>">
  <meta property="og:type" content="article">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
  <link rel="stylesheet" href="/fonts/fonts.css">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/main.css">
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Itineraries", "item": "https://itinerary.wildroadgroup.com/" },
      { "@type": "ListItem", "position": 2, "name": "Travel Inspiration", "item": "https://itinerary.wildroadgroup.com/journal" },
      { "@type": "ListItem", "position": 3, "name": lang === 'en' ? guide.title_en : guide.title_zh, "item": "https://itinerary.wildroadgroup.com/journal/" + guide.slug }
    ]
  }) %>
  </script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": lang === 'en' ? guide.title_en : guide.title_zh,
    "url": "https://itinerary.wildroadgroup.com/journal/" + guide.slug,
    "publisher": { "@type": "Organization", "name": "WR Travel", "url": "https://itinerary.wildroadgroup.com" },
    "mainEntityOfPage": "https://itinerary.wildroadgroup.com/journal/" + guide.slug
  }) %>
  </script>
  <script type="application/ld+json">
  <%- JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(function(faq) {
      return { "@type": "Question", "name": lang === 'en' ? faq.q_en : faq.q_zh, "acceptedAnswer": { "@type": "Answer", "text": lang === 'en' ? faq.a_en : faq.a_zh } };
    })
  }) %>
  </script>
  <style>
    .gd-hero {
      background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 100%);
      padding: 50px 24px 40px;
      text-align: center;
    }
    .gd-hero .back-link { color: rgba(255,255,255,0.5); font-size: 13px; text-decoration: none; display: block; margin-bottom: 16px; }
    .gd-hero h1 { color: #fff; font-family: 'Playfair Display',serif; font-size: 30px; margin: 0 0 8px; line-height: 1.4; }
    .gd-hero .gd-type-badge {
      display: inline-block; font-size: 11px; font-weight: 600; padding: 4px 14px;
      border-radius: 14px; background: rgba(200,169,110,0.3); color: #c8a96e;
      text-transform: uppercase; letter-spacing: 0.5px; margin-top: 8px;
    }
    .gd-content { max-width: 820px; margin: 40px auto; padding: 0 24px; }
    .gd-dest-intro {
      background: #f9f7f3; border-radius: 12px; padding: 24px; margin-bottom: 36px;
      border-left: 4px solid #c8a96e; line-height: 1.8; font-size: 14px; color: #555;
    }
    .gd-section { margin-bottom: 32px; }
    .gd-section h2 { font-size: 20px; font-weight: 700; margin: 0 0 12px; color: #1a1a2e; }
    .gd-section h3 { font-size: 16px; font-weight: 600; margin: 20px 0 8px; color: #333; }
    .gd-section p { font-size: 14px; line-height: 1.9; color: #555; margin: 0 0 12px; }
    .gd-section ul { padding-left: 20px; margin: 0 0 12px; }
    .gd-section li { font-size: 14px; line-height: 1.8; color: #555; margin-bottom: 4px; }
    .gd-budget-table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 14px; }
    .gd-budget-table th { background: #1a1a2e; color: #fff; padding: 10px 16px; text-align: left; }
    .gd-budget-table td { padding: 10px 16px; border-bottom: 1px solid #eee; }
    .gd-budget-table tr:hover td { background: #f9f7f3; }
    .gd-faq { margin-top: 48px; border-top: 2px solid #e8e0d0; padding-top: 32px; }
    .gd-faq h2 { font-size: 20px; font-weight: 700; margin: 0 0 20px; color: #1a1a2e; }
    .gd-faq-item { margin-bottom: 16px; }
    .gd-faq-q { font-size: 15px; font-weight: 600; color: #333; margin-bottom: 6px; }
    .gd-faq-a { font-size: 14px; line-height: 1.8; color: #666; }
    .gd-related { margin-top: 48px; border-top: 2px solid #e8e0d0; padding-top: 32px; max-width: 1200px; margin-left: auto; margin-right: auto; padding-left: 24px; padding-right: 24px; padding-bottom: 80px; }
    .gd-related h2 { font-size: 20px; font-weight: 700; margin: 0 0 20px; color: #1a1a2e; }
    .gd-related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
  </style>
<%- include('partials/ga') %>
</head>
<body>
  <button id="langToggle" onclick="toggleLang()" class="lang-toggle"><%= lang === 'en' ? '中' : 'EN' %></button>

  <div class="gd-hero">
    <a href="/journal<%= lang === 'en' ? '?lang=en' : '' %>" class="back-link"><%= lang === 'en' ? '← All Guides' : '← 全部指南' %></a>
    <h1><%= lang === 'en' ? guide.title_en : guide.title_zh %></h1>
    <span class="gd-type-badge"><%= typeLabel %></span>
  </div>

  <div class="gd-content">
    <!-- Destination intro -->
    <% var introText = lang === 'en' ? destInfo.en : destInfo.zh; %>
    <% if (introText) { %>
      <div class="gd-dest-intro">
        <%= introText %>
      </div>
    <% } %>

    <!-- Main content sections based on guide type -->
    <%- contentHtml %>
  </div>

  <!-- FAQ section -->
  <div class="gd-content">
    <div class="gd-faq">
      <h2><%= lang === 'en' ? 'Frequently Asked Questions' : '常见问题' %></h2>
      <% faqItems.forEach(function(faq) { %>
        <div class="gd-faq-item">
          <div class="gd-faq-q"><%= lang === 'en' ? faq.q_en : faq.q_zh %></div>
          <div class="gd-faq-a"><%= lang === 'en' ? faq.a_en : faq.a_zh %></div>
        </div>
      <% }); %>
    </div>
  </div>

  <!-- Related itineraries -->
  <% if (relatedTrips && relatedTrips.length > 0) { %>
    <div class="gd-related">
      <h2><%= lang === 'en' ? 'Related Itineraries' : '相关行程推荐' %></h2>
      <div class="gd-related-grid">
        <% relatedTrips.forEach(function(item) { %>
          <a class="card" href="/<%= item.id %><%= lang === 'en' ? '?lang=en' : '' %>" style="text-decoration:none;color:inherit;background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.06);transition:transform 0.3s;">
            <div style="position:relative;height:180px;overflow:hidden;">
              <picture>
                <source srcset="/<%= item.coverImage.replace(/\.(jpg|jpeg|png)$/i, '.webp') %>" type="image/webp">
                <img src="/<%= item.coverImage %>" alt="<%= lang === 'en' ? (item.title_en || item.title) : item.title %>" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;">
              </picture>
              <div style="position:absolute;top:16px;left:16px;background:rgba(0,0,0,0.55);color:#fff;font-size:12px;font-weight:600;padding:6px 14px;border-radius:20px;"><%= lang === 'en' ? item.days + 'D ' + (item.days - 1) + 'N' : item.days + '天' + (item.days - 1) + '晚' %></div>
            </div>
            <div style="padding:14px 16px;">
              <h3 style="font-size:15px;margin:0 0 4px;"><%= lang === 'en' ? (item.title_en || item.title) : item.title %></h3>
              <p style="font-size:13px;color:#888;margin:0;line-height:1.5;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;"><%= lang === 'en' ? (item.description_en || item.description) : item.description %></p>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  <% } %>

  <script>
    function toggleLang() {
      const url = new URL(window.location); const next = url.searchParams.get('lang') === 'en' ? 'zh' : 'en';
      localStorage.setItem('wr_lang', next); url.searchParams.set('lang', next); window.location = url.toString();
    }
  </script>
</body>
</html>
