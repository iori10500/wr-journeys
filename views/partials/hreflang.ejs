<%
  // Usage: include with { canonicalPath: '/foo' }  (the bare path without /en prefix)
  const _site = 'https://itinerary.wildroadgroup.com';
  const _path = typeof canonicalPath !== 'undefined' && canonicalPath ? canonicalPath : '/';
  const _zhUrl = _site + _path;
  const _enUrl = _site + (_path === '/' ? '/en' : '/en' + _path);
  const _canonicalUrl = lang === 'en' ? _enUrl : _zhUrl;
%><link rel="canonical" href="<%= _canonicalUrl %>">
<link rel="alternate" hreflang="zh-CN" href="<%= _zhUrl %>">
<link rel="alternate" hreflang="en" href="<%= _enUrl %>">
<link rel="alternate" hreflang="x-default" href="<%= _zhUrl %>">
